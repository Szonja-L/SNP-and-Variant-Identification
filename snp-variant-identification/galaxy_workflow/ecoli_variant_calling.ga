{
  "a_galaxy_workflow": "true",
  "annotation": "SNP & Variant Identification pipeline for bacterial genomes. Aligns Illumina paired-end reads to a reference genome and calls variants using FreeBayes, with SnpEff annotation. Designed for E. coli (or any bacterial genome on NCBI). Portfolio project — Szonja Fekete, 2024.",
  "creator": [
    {
      "class": "Person",
      "identifier": "https://github.com/szfekete",
      "name": "Szonja Fekete"
    }
  ],
  "format-version": "0.1",
  "license": "MIT",
  "name": "Bacterial SNP & Variant Identification (FastQC → Trimmomatic → BWA-MEM → FreeBayes → SnpEff)",
