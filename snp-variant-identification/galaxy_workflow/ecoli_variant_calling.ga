    "13": {
      "annotation": "STEP 6: Call SNPs and small indels using FreeBayes (haplotype-based Bayesian variant caller). Key settings: --min-mapping-quality 20, --min-base-quality 20, --min-alternate-fraction 0.05, --min-alternate-count 3. For clonal bacteria, expect AF close to 1.0.",
      "content_id": "toolshed.g2.bx.psu.edu/repos/devteam/freebayes/freebayes/1.3.6+galaxy0",
